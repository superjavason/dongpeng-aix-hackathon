generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 运行时（Prisma Client）使用的连接串，可指向连接池（如 Neon pooler）。
  url       = env("DATABASE_URL")
  // 迁移引擎使用的直连串（不走连接池）。Prisma migrate 需要直连，
  // Neon 用户请将主机名中的 "-pooler" 去掉。本地开发可与 DATABASE_URL 相同。
  directUrl = env("DIRECT_URL")
}

enum Role {
  participant
  judge
  admin
}

enum EventPhase {
  draft
  registration
  in_progress
  judging
  ended
}

enum MembershipStatus {
  pending
  approved
  rejected
}

enum TeamRole {
  owner
  member
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  passwordHash String?
  ssoId        String?  @unique
  role         Role     @default(participant)
  avatarUrl    String?
  bio          String?
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())

  ownedProjects Project[]          @relation("ProjectOwner")
  memberships   Membership[]
  assignments   JudgeAssignment[]
  scores        Score[]
  likes         ProjectLike[]
}

model Event {
  id               String     @id @default(cuid())
  name             String
  description      String
  track            String?
  phase            EventPhase @default(draft)
  isActive         Boolean    @default(false)
  startAt          DateTime?
  endAt            DateTime?
  scoreCriteria    Json // [{ key, label, weight, max }]
  resultsPublished Boolean    @default(false)
  maxLikesPerUser  Int        @default(10) // 每用户每赛事点赞上限，后台可配置
  createdAt        DateTime   @default(now())

  projects Project[]
  likes    ProjectLike[]
}

model Project {
  id            String   @id @default(cuid())
  eventId       String
  ownerId       String
  title         String
  tagline       String
  description   String
  track         String
  maxMembers    Int      @default(4)
  coverImageUrl String?
  createdAt     DateTime @default(now())

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner       User         @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  submission  Submission?
  likes       ProjectLike[]
}

model ProjectLike {
  id        String   @id @default(cuid())
  eventId   String // 冗余存储，便于按赛事统计用户已用额度
  projectId String
  userId    String
  createdAt DateTime @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId]) // 同一用户对同一项目至多 1 票
  @@index([eventId, userId]) // 统计用户在该赛事已用票数
  @@index([projectId]) // 统计项目得票数
}

model Membership {
  id        String           @id @default(cuid())
  projectId String
  userId    String
  status    MembershipStatus @default(pending)
  teamRole  TeamRole         @default(member)
  message   String?
  createdAt DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Submission {
  id          String   @id @default(cuid())
  projectId   String   @unique
  title       String
  summary     String
  repoUrl     String?
  demoUrl     String?
  videoUrl    String?
  images      Json     @default("[]") // string[]
  attachments Json     @default("[]") // { name, url }[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scores  Score[]
  judgeAssignments JudgeAssignment[]
}

model JudgeAssignment {
  id           String @id @default(cuid())
  eventId      String
  judgeId      String
  submissionId String

  judge      User       @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([judgeId, submissionId])
}

model Score {
  id           String   @id @default(cuid())
  submissionId String
  judgeId      String
  scores       Json // { [criterionKey]: number }
  total        Float
  comment      String?
  submittedAt  DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judge      User       @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  @@unique([submissionId, judgeId])
}
